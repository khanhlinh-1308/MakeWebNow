<%@ page contentType="text/html;charset=UTF-8" language="java"%>

<!DOCTYPE html>
<html lang="vi">

<head>

<meta charset="UTF-8">

<meta name="viewport"
      content="width=device-width, initial-scale=1.0">

<title>Make Web Now</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet">

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

<link rel="stylesheet"
      href="assets/css/index.css">

</head>

<body>

<nav class="navbar navbar-expand-lg bg-white shadow-sm">

    <div class="container">

        <a class="navbar-brand fw-bold logo">

            <i class="fa-solid fa-code"></i>

            Make Web Now

        </a>

        <div>

            <a href="login"
               class="btn btn-outline-primary me-2">

                Đăng nhập

            </a>

            <a href="register"
               class="btn btn-pink">

                Đăng ký

            </a>

        </div>

    </div>

</nav>

<section class="hero">

    <div class="container text-center">

        <h1>

            Thiết kế Website bằng cách kéo thả

        </h1>

        <p>

            Không cần biết lập trình vẫn có thể tạo website
            đẹp chỉ trong vài phút.

        </p>

        <a href="register"
           class="btn btn-start">

            Bắt đầu ngay

        </a>

    </div>

</section>

<section class="container py-5">

    <h2 class="text-center mb-5">

        Tính năng nổi bật

    </h2>

    <div class="row text-center">

        <div class="col-md-3">

            <i class="fa-solid fa-hand-pointer feature-icon"></i>

            <h5>Kéo & Thả</h5>

            <p>Tạo website bằng thao tác kéo thả đơn giản.</p>

        </div>

        <div class="col-md-3">

            <i class="fa-solid fa-eye feature-icon"></i>

            <h5>Preview</h5>

            <p>Xem trước website ngay lập tức.</p>

        </div>

        <div class="col-md-3">

            <i class="fa-solid fa-download feature-icon"></i>

            <h5>Download</h5>

            <p>Tải website sau khi hoàn thành.</p>

        </div>

        <div class="col-md-3">

            <i class="fa-solid fa-mobile-screen feature-icon"></i>

            <h5>Responsive</h5>

            <p>Hiển thị đẹp trên mọi thiết bị.</p>

        </div>

    </div>

</section>

<footer>

    © 2026 Make Web Now

</footer>

